{% extends 'base.html.twig' %}

{% block title %}New Category{% endblock %}
{% block admin_page_title %}Create New Category{% endblock %}
{% block admin_content %}
<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            {# Back Link with icon #}
            <div class="mb-4">
                <a href="{{ path('app_category_index') }}" class="text-decoration-none text-secondary fw-bold">
                    <i class="fas fa-arrow-left me-2"></i> Back to Categories
                </a>
            </div>

            {# Form Card #}
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4 p-lg-5">

                    {# Include the category form #}
                    {{ include('category/_form.html.twig') }}

                    <p class="mt-3 text-muted small">
                        Provide a name for your category. Fields marked with * are required.
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
