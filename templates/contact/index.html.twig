{% extends 'base.html.twig' %}

{% block title %}Contact Us — Moodura SCENT{% endblock %}

{% block stylesheets %}
{{ parent() }}
{% endblock %}

{% block body %}
<div class="cp">

  {# ── NAV ── #}
  <nav class="cp-nav">
    <a href="{{ path('app_home') }}" class="brand">
      Moodura
      <span>SCENTS</span>
    </a>
    <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul class="nav-right" id="mobileMenu">
      <li><a href="{{ path('app_home') }}">Home</a></li>
      <li><a href="{{ path('app_about') }}">About Us</a></li>
      <li><a href="{{ path('app_contact') }}" class="active">Contact Us</a></li>
      <li>
        {% if app.user %}
          <div class="dropdown">
            <button class="btn btn-sm dropdown-toggle" type="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="background:var(--moodura-violet);color:#fff;padding:.45rem 1.2rem;border-radius:999px;font-family:sans-serif;font-size:.85rem;font-weight:600;letter-spacing:.05em;border:none;cursor:pointer;">
              <i class="fas fa-user me-2"></i>{{ app.user.username }}
            </button>
            <ul class="dropdown-menu" aria-labelledby="userDropdown" style="color:#333;">
              <li><a class="dropdown-item" href="{{ path('app_logout') }}" style="color:#333;"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
            </ul>
          </div>
        {% else %}
          <a href="{{ path('app_login') }}" class="login-btn">Login</a>
        {% endif %}
      </li>
    </ul>
  </nav>

  {# ── HERO ── #}
  <section class="contact-hero">
    <p class="eyebrow">Get in Touch</p>
    <h1>We'd Love to<br>Hear from You</h1>
    <p>Whether it's a question about a scent, an order, or just a mood you can't name we're here for it.</p>
  </section>

  {# ── MAIN BODY: INFO + FORM ── #}
  <div class="contact-body">

    {# LEFT — Contact Info #}
    <div class="contact-info">
      <p class="sec-label">Reach Us</p>
      <h2>Let's Start a Conversation</h2>
      <div class="contact-divider"></div>
      <p class="intro">Our team responds within 24 hours. For order concerns, have your order number ready and we'll sort it out right away.</p>

      <div class="info-cards">
        <div class="info-card">
          <div class="info-icon">📧</div>
          <div class="info-card-text">
            <p class="ic-label">Email</p>
            <p class="ic-value">hello@moodurasscent.com</p>
          </div>
        </div>
        <div class="info-card">
          <div class="info-icon">📞</div>
          <div class="info-card-text">
            <p class="ic-label">Phone</p>
            <p class="ic-value">+63 912 345 6789</p>
          </div>
        </div>
        <div class="info-card">
          <div class="info-icon">📍</div>
          <div class="info-card-text">
            <p class="ic-label">Location</p>
            <p class="ic-value">Cebu City, Philippines</p>
          </div>
        </div>
        <div class="info-card">
          <div class="info-icon">🕐</div>
          <div class="info-card-text">
            <p class="ic-label">Business Hours</p>
            <p class="ic-value">Mon – Sat, 9AM – 6PM</p>
          </div>
        </div>
      </div>

      <div class="social-strip">
        <p>Follow Us</p>
        <div class="social-links">
          <a href="#" class="social-link">IG</a>
          <a href="#" class="social-link">FB</a>
          <a href="#" class="social-link">TT</a>
          <a href="#" class="social-link">PI</a>
        </div>
      </div>
    </div>

    {# RIGHT — Contact Form (Symfony Backend) #}
    <div class="contact-form-wrap">
      <div class="form-header">
        <h3>Send Us a Message</h3>
        <p>Fill out the form and our team will get back to you shortly.</p>
      </div>

      <div class="brevo-badge">
        <span class="dot"></span>
        Powered by Brevo
      </div>

      <form id="contactForm" method="POST" action="{{ path('app_contact_submit') }}" novalidate>
        
        <div class="form-row">
          <div class="form-group">
            <label for="firstName">First Name <span class="req">*</span></label>
            {{ form_widget(form.name, {'id': 'firstName', 'attr': {'placeholder': 'e.g. Vrecin'}}) }}
          </div>
          <div class="form-group">
            <label for="lastName">Last Name</label>
            {{ form_widget(form.lastname, {'id': 'lastName', 'attr': {'placeholder': 'e.g. Reyes'}}) }}
          </div>
        </div>

        <div class="form-group">
          <label for="email">Email Address <span class="req">*</span></label>
          {{ form_widget(form.email, {'id': 'email', 'attr': {'placeholder': 'you@example.com'}}) }}
        </div>

        <div class="form-group">
          <label for="message">Message <span class="req">*</span></label>
          {{ form_widget(form.message, {'id': 'message', 'rows': 5, 'attr': {'placeholder': 'Tell us what\'s on your mind...'}}) }}
        </div>

        {# Hidden fields and CSRF token #}
        {{ form_widget(form._token) }}

        <button type="submit" class="form-submit" id="submitBtn">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M22 2 11 13M22 2 15 22l-4-9-9-4 20-7z"/>
          </svg>
          Send Message
        </button>
      </form>

        <div class="form-feedback success" id="feedbackSuccess">
          ✓ &nbsp; Your message has been sent! We'll get back to you within 24 hours.
        </div>
        <div class="form-feedback error" id="feedbackError">
          ✕ &nbsp; Something went wrong. Please check your details and try again.
        </div>

      <p class="privacy-note">
        By submitting this form you agree to our
        <a href="#">Privacy Policy</a>. We never share your data with third parties.
      </p>
    </div>

  </div>{# /contact-body #}

  {# ── FAQ STRIP ── #}
  <section class="faq-strip">
    <div class="faq-inner">
      <p class="sec-label">Quick Answers</p>
      <h2>Frequently Asked Questions</h2>
      <div class="faq-divider"></div>

      <div class="faq-grid">

        <div class="faq-item" onclick="toggleFaq(this)">
          <div class="faq-question">
            <p>How long does delivery take?</p>
            <span class="faq-toggle">+</span>
          </div>
          <p class="faq-answer">Standard nationwide delivery takes 3–5 business days. Metro areas typically receive orders within 2–3 days. You'll receive tracking details via email once your order is dispatched.</p>
        </div>

        <div class="faq-item" onclick="toggleFaq(this)">
          <div class="faq-question">
            <p>Can I return or exchange a fragrance?</p>
            <span class="faq-toggle">+</span>
          </div>
          <p class="faq-answer">Unopened items can be returned within 14 days of receipt. For exchanges due to damage or incorrect items, please contact us with your order number and photos.</p>
        </div>

        <div class="faq-item" onclick="toggleFaq(this)">
          <div class="faq-question">
            <p>Are your fragrances cruelty-free?</p>
            <span class="faq-toggle">+</span>
          </div>
          <p class="faq-answer">Yes — all Moodura fragrances are cruelty-free and never tested on animals. We are also committed to sourcing sustainable and ethically produced ingredients.</p>
        </div>

        <div class="faq-item" onclick="toggleFaq(this)">
          <div class="faq-question">
            <p>How do I track my order?</p>
            <span class="faq-toggle">+</span>
          </div>
          <p class="faq-answer">Log in to your Moodura account and navigate to the Orders section in your dashboard. You'll find real-time tracking updates for every active order.</p>
        </div>

        <div class="faq-item" onclick="toggleFaq(this)">
          <div class="faq-question">
            <p>Do you ship internationally?</p>
            <span class="faq-toggle">+</span>
          </div>
          <p class="faq-answer">Currently, we ship nationwide within the Philippines. We are working on expanding international shipping and will announce updates through our newsletter.</p>
        </div>

        <div class="faq-item" onclick="toggleFaq(this)">
          <div class="faq-question">
            <p>Can I buy Moodura scents in stores?</p>
            <span class="faq-toggle">+</span>
          </div>
          <p class="faq-answer">We currently operate exclusively online. However, we plan to open pop-up events and partner stores soon — subscribe to our newsletter to be the first to know.</p>
        </div>

      </div>
    </div>
  </section>

  {# ── FOOTER ── #}
  <footer class="cp-footer">
    <div class="footer-top">
      <div>
        <p class="footer-brand-name">Moodura</p>
        <p class="footer-brand-sub">SCENT</p>
        <p class="footer-brand-desc">Express yourself through fragrances inspired by moods and personalities.</p>
      </div>
      <div class="fcol">
        <h4>Pages</h4>
        <ul>
          <li><a href="{{ path('app_home') }}">Home</a></li>
          <li><a href="{{ path('app_about') }}">About Us</a></li>
          <li><a href="{{ path('app_contact') }}">Contact Us</a></li>
          <li><a href="{{ path('app_login') }}">Login</a></li>
          <li><a href="#">FAQ</a></li>
        </ul>
      </div>
      <div class="fcol">
        <h4>Info</h4>
        <ul>
          <li><a href="#">Privacy Policy</a></li>
          <li><a href="#">Terms & Conditions</a></li>
          <li><a href="#">Returns Policy</a></li>
          <li><a href="#">Shipping Policies</a></li>
          <li><a href="#">Refund Policy</a></li>
          <li><a href="#">Order Tracking</a></li>
        </ul>
      </div>
      <div class="fcol">
        <h4>Follow Us</h4>
        <ul>
          <li><a href="#">Instagram</a></li>
          <li><a href="#">Facebook</a></li>
          <li><a href="#">TikTok</a></li>
          <li><a href="#">Pinterest</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2025, Moodura SCENT — All rights reserved.</p>
    </div>
  </footer>

</div>

<script>
/* ── FAQ accordion ── */
function toggleFaq(el) {
  const wasOpen = el.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
  if (!wasOpen) el.classList.add('open');
}

/* ── Form submission via Fetch API ── */
document.getElementById('contactForm').addEventListener('submit', function(e) {
  e.preventDefault();
  
  const btn = document.getElementById('submitBtn');
  const successMsg = document.getElementById('feedbackSuccess');
  const errorMsg = document.getElementById('feedbackError');
  
  // Reset messages
  successMsg.style.display = 'none';
  errorMsg.style.display = 'none';
  
  btn.innerHTML = 'Sending…';
  btn.disabled = true;
  
  const formData = new FormData(this);
  
  fetch('{{ path('app_contact_submit') }}', {
    method: 'POST',
    body: formData
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      successMsg.style.display = 'flex';
      this.reset();
    } else {
      errorMsg.textContent = '✕ &nbsp; ' + (data.message || 'Failed to send message. Please try again.');
      errorMsg.style.display = 'flex';
    }
  })
  .catch(error => {
    console.error('Error:', error);
    errorMsg.textContent = '✕ &nbsp; Network error. Please check your connection and try again.';
    errorMsg.style.display = 'flex';
  })
  .finally(() => {
    btn.innerHTML = `<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M22 2 11 13M22 2 15 22l-4-9-9-4 20-7z"/>
    </svg> Send Message`;
    btn.disabled = false;
  });
});

  // Mobile menu toggle
  const mobileMenuToggle = document.getElementById('mobileMenuToggle');
  const mobileMenu = document.getElementById('mobileMenu');
  
  function closeMenu() {
    mobileMenu.classList.remove('active');
    mobileMenuToggle.classList.remove('open');
  }
  
  function openMenu() {
    mobileMenu.classList.add('active');
    mobileMenuToggle.classList.add('open');
  }
  
  function toggleMenu() {
    if (mobileMenu.classList.contains('active')) {
      closeMenu();
    } else {
      openMenu();
    }
  }
  
  if (mobileMenuToggle) {
    mobileMenuToggle.addEventListener('click', function(e) {
      e.stopPropagation();
      toggleMenu();
    });
    
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', function(e) {
        closeMenu();
      });
    });
    
    document.addEventListener('click', function(e) {
      if (!mobileMenuToggle.contains(e.target) && !mobileMenu.contains(e.target)) {
        closeMenu();
      }
    });
  }
</script>

<style>
  /* ══════════════════════ NAVBAR BASE STYLES ══════════════════════ */
  .cp-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(135deg, #2E073F 0%, #1a0427 100%);
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 999;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .cp-nav .brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    text-decoration: none;
    font-size: 1.2rem;
    font-weight: 600;
    transition: opacity 0.3s ease;
  }

  .cp-nav .brand:hover {
    opacity: 0.8;
  }

  .cp-nav .brand span {
    font-size: 0.65rem;
    letter-spacing: 1px;
    opacity: 0.8;
  }

  /* Mobile Menu Styles */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-around;
    width: 30px;
    height: 24px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
  }

  .mobile-menu-toggle span {
    width: 100%;
    height: 2px;
    background-color: white;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .mobile-menu-toggle.open span:nth-child(1) {
    transform: rotate(45deg) translate(8px, 8px);
  }

  .mobile-menu-toggle.open span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-toggle.open span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
  }

  /* Responsive Navbar */
  @media (min-width: 769px) {
    .mobile-menu-toggle {
      display: none !important;
    }

    .cp-nav .nav-right {
      display: flex !important;
      position: static !important;
      background: none !important;
      border: none !important;
      box-shadow: none !important;
      top: auto !important;
      flex-direction: row !important;
      list-style: none;
      gap: 2rem;
      margin: 0;
      padding: 0;
    }

    .cp-nav .nav-right li {
      border: none !important;
      padding: 0 !important;
    }

    .cp-nav .nav-right li a {
      display: inline !important;
      padding: 0 !important;
    }
  }

  @media (max-width: 768px) {
    .cp-nav {
      flex-wrap: wrap;
      padding: 1rem 1.5rem;
    }

    .mobile-menu-toggle {
      display: flex;
    }

    .cp-nav .nav-right {
      display: none;
      position: absolute;
      top: 70px;
      left: 0;
      right: 0;
      flex-direction: column;
      background: linear-gradient(135deg, #2E073F 0%, #1a0427 100%);
      padding: 1rem;
      gap: 0;
      border-top: 1px solid rgba(169, 118, 209, 0.3);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);
      z-index: 1000;
      list-style: none;
      margin: 0;
    }

    .cp-nav .nav-right.active {
      display: flex;
    }

    .cp-nav .nav-right li {
      padding: 1rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .cp-nav .nav-right li:last-child {
      border-bottom: none;
    }

    .cp-nav .nav-right li a {
      display: block;
      padding: 0.5rem 0;
      color: #fff;
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .cp-nav .nav-right li a:hover {
      color: var(--moodura-violet, #A976D1);
    }

    .cp-nav .nav-right li a.login-btn {
      background: var(--moodura-violet, #A976D1);
      color: #fff;
      padding: 0.45rem 1.2rem;
      border-radius: 999px;
      display: inline-block;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.05em;
    }

    /* Contact Hero */
    .contact-hero {
      padding: 2rem 1.5rem;
    }

    .contact-hero h1 {
      font-size: 1.75rem;
      line-height: 1.3;
      word-wrap: break-word;
    }

    .contact-hero p {
      font-size: 0.95rem;
      word-wrap: break-word;
    }

    /* Contact Body */
    .contact-body {
      flex-direction: column;
      padding: 1.5rem;
      gap: 2rem;
    }

    .contact-info {
      padding: 1.5rem;
    }

    .contact-info h2 {
      font-size: 1.3rem;
    }

    .contact-info p {
      font-size: 0.9rem;
      word-wrap: break-word;
    }

    .info-cards {
      flex-direction: column;
      gap: 1rem;
    }

    .info-card {
      padding: 1rem;
    }

    /* Form Styles */
    .contact-form-wrap {
      padding: 1.5rem;
      width: 100%;
    }

    .form-header h3 {
      font-size: 1.3rem;
    }

    .form-row {
      flex-direction: column;
    }

    .form-group {
      width: 100%;
      margin-bottom: 1rem;
    }

    .form-group label {
      font-size: 0.9rem;
    }

    .form-group input,
    .form-group textarea,
    .form-group select {
      font-size: 1rem;
      padding: 0.75rem;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .form-submit {
      width: 100%;
      padding: 1rem;
      font-size: 0.95rem;
    }

    /* FAQ Section */
    .faq-strip {
      padding: 2rem 1.5rem;
    }

    .faq-strip h2 {
      font-size: 1.5rem;
    }

    .faq-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .faq-question p {
      font-size: 0.9rem;
      word-wrap: break-word;
    }

    .faq-answer {
      font-size: 0.85rem;
    }

    /* Footer */
    .cp-footer {
      padding: 2rem 1.5rem;
    }

    .footer-top {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .footer-col h4 {
      font-size: 0.95rem;
    }

    .footer-col ul li a {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .cp-nav {
      padding: 0.75rem 1rem;
    }

    .brand {
      font-size: 0.9rem;
    }

    .brand span {
      font-size: 0.55rem;
    }

    .contact-hero h1 {
      font-size: 1.4rem;
    }

    .contact-hero p {
      font-size: 0.85rem;
    }

    .contact-body {
      padding: 1rem;
    }

    .contact-form-wrap {
      padding: 1rem;
    }

    .form-group input,
    .form-group textarea {
      font-size: 16px;
    }

    .info-card {
      padding: 0.75rem;
    }

    .ic-label {
      font-size: 0.8rem;
    }

    .ic-value {
      font-size: 0.75rem;
    }

    .faq-strip {
      padding: 1.5rem 1rem;
    }

    .faq-strip h2 {
      font-size: 1.3rem;
    }

    .privacy-note {
      font-size: 0.75rem;
      padding: 0 1rem;
    }
  }
</style>
{% endblock %}