{% extends 'base.html.twig' %}
{% import 'macros/datatables.html.twig' as dt %}
{% block title %}User Management{% endblock %}

{% block admin_page_title %}User Management{% endblock %}

{% block admin_content %}

<div class="moodura-page-header">
    <div class="header-content">
        <div class="header-text">
            <h1 class="header-title">Team Directory</h1>
            <p class="header-subtitle">Manage user accounts and permissions</p>
        </div>
        <a class="moodura-btn-primary" href="{{ path('app_user_new') }}">
            <i class="fas fa-user-plus"></i>
            <span>Add New User</span>
        </a>
    </div>
</div>

{# Filter Panel #}
<div class="moodura-filter-panel">
    <form method="get" action="{{ path('app_user_index') }}" class="filter-form">
        
        <div class="filter-grid">
            {# Search Input #}
            <div class="filter-item filter-search">
                <label class="filter-label">
                    <i class="fas fa-search"></i>
                    Search Users
                </label>
                <div class="moodura-input-wrapper">
                    <input type="text"
                           name="search"
                           class="moodura-input"
                           placeholder="Name, username, or email..."
                           value="{{ app.request.get('search') }}">
                </div>
            </div>

            {# Role Filter #}
            <div class="filter-item">
                <label class="filter-label">
                    <i class="fas fa-user-tag"></i>
                    Role
                </label>
                <select name="role" class="moodura-select">
                    <option value="">All Roles</option>
                    <option value="ROLE_USER" {% if app.request.get('role') == 'ROLE_USER' %}selected{% endif %}>User</option>
                    <option value="ROLE_STAFF" {% if app.request.get('role') == 'ROLE_STAFF' %}selected{% endif %}>Staff</option>
                    <option value="ROLE_ADMIN" {% if app.request.get('role') == 'ROLE_ADMIN' %}selected{% endif %}>Admin</option>
                </select>
            </div>

            {# Status Filter #}
            <div class="filter-item">
                <label class="filter-label">
                    <i class="fas fa-circle"></i>
                    Status
                </label>
                <select name="status" class="moodura-select">
                    <option value="">All Status</option>
                    <option value="active" {% if app.request.get('status') == 'active' %}selected{% endif %}>Active</option>
                    <option value="inactive" {% if app.request.get('status') == 'inactive' %}selected{% endif %}>Inactive</option>
                </select>
            </div>

            {# Action Buttons #}
            <div class="filter-item filter-actions">
                <button type="submit" class="moodura-btn-filter">
                    <i class="fas fa-filter"></i>
                    Apply
                </button>
            </div>
        </div>
    </form>
</div>

{# Users Table Card #}
<div class="moodura-table-card">
    <div data-turbo="false">
        <div class="table-responsive">
            <table id="userTable" class="moodura-table">
                <thead>
                    <tr>
                        <th class="col-id">ID</th>
                        <th class="col-username">Username</th>
                        <th class="col-email">Email</th>
                        <th class="col-name">Full Name</th>
                        <th class="col-role">Role</th>
                        <th class="col-date">Joined</th>
                        <th class="col-status">Status</th>
                        <th class="col-actions">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    {% for user in users %}
                        <tr class="table-row">
                            <td class="col-id">
                                <span class="id-badge">#{{ user.id }}</span>
                            </td>
                            <td class="col-username">
                                <div class="user-cell">
                                    <div class="user-avatar">
                                        {{ user.username|slice(0, 1)|upper }}
                                    </div>
                                    <span class="username-text">{{ user.username }}</span>
                                </div>
                            </td>
                            <td class="col-email">{{ user.email }}</td>
                            <td class="col-name">{{ user.name }}</td>
                            <td class="col-role">
                                {% set roleDisplay = user.roles|json_encode|replace({'"': '', '[': '', ']': '', 'ROLE_': ''}) %}
                                <span class="moodura-role-tag">{{ roleDisplay }}</span>
                            </td>
                            <td class="col-date">
                                <span class="date-text">{{ user.createdAt ? user.createdAt|date('M d, Y') : '' }}</span>
                            </td>
                            <td class="col-status">
                                {% if user.isActive %}
                                    <span class="moodura-status-badge active">
                                        <i class="fas fa-check-circle"></i> Active
                                    </span>
                                {% else %}
                                    <span class="moodura-status-badge inactive">
                                        <i class="fas fa-times-circle"></i> Inactive
                                    </span>
                                {% endif %}
                            </td>
                            <td class="col-actions">
                                <div class="action-buttons">
                                    <a class="action-btn view" href="{{ path('app_user_show', {'id': user.id}) }}" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a class="action-btn edit" href="{{ path('app_user_edit', {'id': user.id}) }}" title="Edit User">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8" class="empty-state-cell">
                                <div class="empty-state">
                                    <i class="fas fa-users"></i>
                                    <p>No users found</p>
                                    <span>Try adjusting your filters or create a new user</span>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>


{% block javascripts %}
    {{ parent() }}
    {{ dt.datatable('userTable', {'pageLength': 10, 'searching': false}) }}
{% endblock %}

{% endblock %}