<form method="post" action="{{ path('app_orders_delete', {'id': order.id}) }}" onsubmit="return confirm('Are you sure you want to delete this order?');" style="display:inline-block; margin-left:4px;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
        <i class="bi bi-trash"></i>
    </button>
</form>
