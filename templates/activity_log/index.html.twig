{% extends 'base.html.twig' %}
{% import 'macros/datatables.html.twig' as dt %}

{% block title %}Activity Logs{% endblock %}

{% block admin_page_title %}Activity Logs{% endblock %}

{% block admin_content %}
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <small class="text-muted">Recent activity across the system</small>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table id="activityTable" class="table logs-table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>User</th>
                        <th>Action</th>
                        <th>Target</th>
                        <th>IP</th>
                        <th>Date & Time</th>
                    </tr>
                </thead>
                <tbody>
                {% for log in logs %}
                    <tr>
                        <td class="align-middle">
                            <div class="d-flex align-items-center">
                                <div class="avatar bg-secondary text-white rounded-circle d-inline-flex align-items-center justify-content-center me-2" style="width:34px;height:34px;font-size:0.9rem;">
                                    {{ log.username is defined and log.username ? log.username|slice(0,1)|upper : 'U' }}
                                </div>
                                <div>
                                    <div class="fw-semibold">{{ log.username ?? 'System' }}</div>
                                    <div class="text-muted small">{{ log.userEmail ?? '' }}</div>
                                </div>
                            </div>
                        </td>
                        <td class="align-middle">
                            <span class="action-badge action-{{ log.action|lower }} badge rounded-pill">
                                {% if log.action == 'Create' %}
                                    <i class="fas fa-plus-circle me-1"></i>
                                {% elseif log.action == 'Update' %}
                                    <i class="fas fa-edit me-1"></i>
                                {% elseif log.action == 'Delete' %}
                                    <i class="fas fa-trash me-1"></i>
                                {% elseif log.action == 'Login' %}
                                    <i class="fas fa-sign-in-alt me-1"></i>
                                {% elseif log.action == 'Logout' %}
                                    <i class="fas fa-sign-out-alt me-1"></i>
                                {% endif %}
                                {{ log.action }}
                            </span>
                        </td>
                        <td class="align-middle text-truncate" style="max-width:300px;">{{ log.targetData }}</td>
                        <td class="align-middle text-muted small">{{ log.ipAddress }}</td>
                        <td class="align-middle text-muted small">{{ log.createdAt|date('M d, Y h:i A') }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-5 empty-state">
                            <i class="fas fa-clipboard-list" style="font-size: 3rem; color: #e9ecef; margin-bottom: 1rem;"></i>
                            <div class="text-muted">No activity logs found</div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .logs-table th { white-space: nowrap; }
    .action-badge.action-create { background:#198754; color:#fff; }
    .action-badge.action-update { background:#0d6efd; color:#fff; }
    .action-badge.action-delete { background:#dc3545; color:#fff; }
    .action-badge.action-login { background:#0dcaf0; color:#000; }
    .action-badge.action-logout { background:#6c757d; color:#fff; }
    .avatar { flex: 0 0 auto; }
    .empty-state i { opacity: 0.7; }
</style>

{% block javascripts %}
    {{ parent() }}
    {{ dt.datatable('activityTable', {
        'pageLength': 10,
        'searching': true,
        'ordering': true,
        'order': [[4, 'desc']],
        'dom': "<'row mb-3'<'col-md-6'l><'col-md-6 text-end'f>>" ~ "t" ~ "<'row mt-3'<'col-12'p>>"
    }) }}
{% endblock %}

{% endblock %}