{{ form_start(form) }}

<div class="mb-3">
    {{ form_label(form.status) }}
    {{ form_widget(form.status, {'attr': {'class': 'form-select'}}) }}
    {{ form_errors(form.status) }}
</div>

<h5 class="mb-3">Items</h5>

{# Build prototype in a Twig variable and escape the whole thing for the data attribute #}
{% set item_prototype %}
    <div class="item-row row align-items-center mb-2">
        <div class="col-md-5">{{ form_widget(form.items.vars.prototype.product, {'attr': {'class': 'form-select product-select'}}) }}</div>
            <div class="col-md-2">
                <label class="form-label small">Quantity</label>
                {{ form_widget(form.items.vars.prototype.quantity, {'attr': {'class': 'form-control quantity-input', 'style': 'width: 80px;', 'type': 'number', 'min': 1, 'step': 1, 'value': 1}}) }}
            </div>
        <div class="col-auto">
            <label class="form-label small">Total</label>
            <input type="text" class="form-control price-display" style="width: 120px;" placeholder="₱0.00" readonly>
        </div>
        <div class="col-md-2 text-end">
            <button type="button" class="btn btn-danger remove-item-btn">
                <i class="bi bi-trash"></i>
            </button>
        </div>
    </div>
{% endset %}

<div class="order-items"
     data-index="{{ form.items|length }}"
     data-prototype="{{ item_prototype|e('html_attr') }}"
>
    {% for item in form.items %}
        <div class="item-row row align-items-center mb-2">
            <div class="col-md-5">{{ form_widget(item.product, {'attr': {'class': 'form-select product-select'}}) }}</div>
            <div class="col-md-2">
                <label class="form-label small">Quantity</label>
                {{ form_widget(item.quantity, {'attr': {'class': 'form-control quantity-input', 'style': 'width: 80px;', 'type': 'number', 'min': 1, 'step': 1, 'value': 1}}) }}
            </div>
                    <div class="col-auto">
                        <label class="form-label small">Total</label>
                        <input type="text" class="form-control price-display" style="width: 120px;" placeholder="₱0.00" readonly>
                    </div>
            <div class="col-md-2 text-end">
                <button type="button" class="btn btn-danger remove-item-btn">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        </div>
    {% endfor %}
</div>

<button type="button" class="btn btn-outline-primary mt-2" id="add-item-btn">
    <i class="bi bi-plus-circle"></i> Add Item
</button>

<div class="row mt-3 justify-content-end totals-row">
    <div class="col-auto">
        <div class="d-flex align-items-center">
            <label class="me-2 mb-0">Subtotal:</label>
            <input type="text" id="subtotal-display" class="form-control-plaintext text-end" style="width:120px;" value="₱0.00" readonly>
        </div>
    </div>
    <div class="col-auto ms-3">
        <div class="d-flex align-items-center">
            <label class="me-2 mb-0">Total:</label>
            <input type="text" id="total-display" class="form-control-plaintext text-end" style="width:120px; font-weight:600;" value="₱0.00" readonly>
        </div>
    </div>
</div>

<div class="mt-3">
    <button class="btn btn-success">{{ button_label|default('Save') }}</button>
</div>

{{ form_end(form) }}

<script>
(function(){
    function initOrderForm() {
        const collectionHolder = document.querySelector('.order-items');
        if (!collectionHolder) return;
        // prevent double init on turbo/partial loads
        if (collectionHolder.dataset.initialized === '1') return;
        collectionHolder.dataset.initialized = '1';

        const addButton = document.getElementById('add-item-btn');

        // ensure index is numeric
        collectionHolder.dataset.index = parseInt(collectionHolder.dataset.index || collectionHolder.querySelectorAll('.item-row').length || 0, 10);

        function createRowFromPrototype(index) {
            const prototype = collectionHolder.dataset.prototype;
            const newForm = prototype.replace(/__name__/g, index);
            const temp = document.createElement('div');
            temp.innerHTML = newForm.trim();
            return temp.firstElementChild;
        }

        function recalcTotals() {
            let subtotal = 0;
            collectionHolder.querySelectorAll('.item-row').forEach(r => {
                const pd = r.querySelector('.price-display');
                if (!pd) return;
                const num = parseFloat((pd.value || '').replace(/[^0-9.-]+/g, '')) || 0;
                subtotal += num;
            });

            const subtotalEl = document.getElementById('subtotal-display');
            const totalEl = document.getElementById('total-display');
            if (subtotalEl) subtotalEl.value = `₱${subtotal.toFixed(2)}`;
            if (totalEl) totalEl.value = `₱${subtotal.toFixed(2)}`;
        }

        function updatePriceDisplay(row) {
            const productSelect = row.querySelector('.product-select');
            const quantityInput = row.querySelector('.quantity-input');
            const priceDisplay = row.querySelector('.price-display');

            if (!productSelect || !priceDisplay) return;

            // sanitize quantity
            if (quantityInput) {
                let v = parseInt(quantityInput.value, 10);
                if (isNaN(v) || v < 1) v = 1;
                quantityInput.value = v;
            }

            const selectedOption = productSelect.options[productSelect.selectedIndex];
            const price = parseFloat((selectedOption && selectedOption.dataset && selectedOption.dataset.price) || 0) || 0;
            const quantity = parseInt((quantityInput && quantityInput.value) || 1, 10) || 1;
            const total = price * quantity;

            priceDisplay.value = `₱${total.toFixed(2)}`;
            recalcTotals();
        }

        function attachEvents(row) {
            const removeBtn = row.querySelector('.remove-item-btn');
            if (removeBtn) {
                removeBtn.addEventListener('click', () => { row.remove(); recalcTotals(); });
            }

            const productSelect = row.querySelector('.product-select');
            const quantityInput = row.querySelector('.quantity-input');

            if (productSelect) productSelect.addEventListener('change', () => updatePriceDisplay(row));
            if (quantityInput) quantityInput.addEventListener('input', () => updatePriceDisplay(row));

            // initialize
            updatePriceDisplay(row);
        }

        if (addButton) {
            addButton.addEventListener('click', () => {
                const index = parseInt(collectionHolder.dataset.index, 10);
                const row = createRowFromPrototype(index);
                collectionHolder.dataset.index = index + 1;
                attachEvents(row);
                collectionHolder.appendChild(row);
            });
        }

        // Attach to existing rows
        collectionHolder.querySelectorAll('.item-row').forEach(row => attachEvents(row));
    }

    document.addEventListener('DOMContentLoaded', initOrderForm);
    document.addEventListener('turbo:load', initOrderForm);
})();
</script>
