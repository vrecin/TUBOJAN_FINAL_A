{% extends 'base.html.twig' %}
{% import 'macros/datatables.html.twig' as dt %}

{% block title %}Category Management{% endblock %}
{% block admin_page_title %}Category Management{% endblock %}

{% block admin_content %}
<div class="moodura-page-header">
    <div class="header-content">
        <div class="header-text">
            <h1 class="header-title">Category Management</h1>
            <p class="header-subtitle">Organize and manage your product categories</p>
        </div>
        <a class="moodura-btn-primary" href="{{ path('app_category_new') }}">
            <i class="fas fa-plus-circle"></i>
            <span>Add Category</span>
        </a>
    </div>
</div>

{# Search Section #}
<div class="moodura-search-card">
    <form method="get" action="{{ path('app_category_index') }}" class="search-form">
        <div class="search-wrapper">
            <div class="search-input-container">
                <i class="fas fa-search search-icon"></i>
                <input type="text"
                       name="search"
                       class="moodura-search-input"
                       placeholder="Search categories by name..."
                       value="{{ app.request.get('search') }}">
            </div>
            
            <button type="submit" class="moodura-search-btn">
                <i class="fas fa-filter"></i>
                <span>Apply Filter</span>
            </button>
        </div>
    </form>
</div>

{# Table Card #}
<div class="moodura-table-card">
    <div data-turbo="false">
        <div class="table-responsive">
            <table id="categoryTable" class="moodura-table">
                <thead>
                    <tr>
                        <th class="col-id">ID</th>
                        <th class="col-name">Category Name</th>
                        <th class="col-date">Created Date</th>
                        <th class="col-actions">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    {% for category in categories %}
                        <tr class="table-row">
                            <td class="col-id">
                                <span class="id-badge">#{{ category.id }}</span>
                            </td>
                            <td class="col-name">
                                <div class="category-cell">
                                    <div class="category-avatar">
                                        {{ category.name|slice(0, 2)|upper }}
                                    </div>
                                    <span class="category-name-text">{{ category.name }}</span>
                                </div>
                            </td>
                            <td class="col-date">
                                <span class="date-text">{{ category.createdAt ? category.createdAt|date('M d, Y H:i') : '-' }}</span>
                            </td>
                            <td class="col-actions">
                                <div class="action-buttons">
                                    <a class="action-btn view" href="{{ path('app_category_show', {'id': category.id}) }}" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a class="action-btn edit" href="{{ path('app_category_edit', {'id': category.id}) }}" title="Edit Category">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="empty-state-cell">
                                <div class="empty-state">
                                    <i class="fas fa-folder-open"></i>
                                    <p>No categories found</p>
                                    <span>Try adjusting your search or create a new category</span>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% block javascripts %}
    {{ parent() }}
    {{ dt.datatable('categoryTable', {'pageLength': 10, 'searching': false}) }}
{% endblock %}
{% endblock %}
