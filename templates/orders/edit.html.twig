{% extends 'base.html.twig' %}

{% block title %}Edit Order{% endblock %}

{% block admin_page_title %}Edit Order #{{ order.id }}{% endblock %}

{% block admin_content %}
<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Order Information</h5>
            </div>
            <div class="card-body">
                <form method="post" action="{{ path('app_orders_edit', {'id': order.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('edit' ~ order.id) }}">
                    
                    <div class="mb-3">
                        <label class="form-label">Order ID</label>
                        <input type="text" class="form-control" value="{{ order.id }}" readonly>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Created At</label>
                        <input type="text" class="form-control" value="{{ order.createdAt ? order.createdAt|date('Y-m-d H:i:s') : '' }}" readonly>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Updated At</label>
                        <input type="text" class="form-control" value="{{ order.updatedAt ? order.updatedAt|date('Y-m-d H:i:s') : '' }}" readonly>
                    </div>
                    
                    <div class="mb-3">
                        <label for="order_status" class="form-label"><strong>Status</strong> <span class="text-danger">*</span></label>
                        <select id="order_status" name="order[status]" class="form-select" required>
                            <option value="Pending" {% if order.status == 'Pending' %}selected{% endif %}>Pending</option>
                            <option value="Approved" {% if order.status == 'Approved' %}selected{% endif %}>Approved</option>
                            <option value="Completed" {% if order.status == 'Completed' %}selected{% endif %}>Completed</option>
                            <option value="Cancelled" {% if order.status == 'Cancelled' %}selected{% endif %}>Cancelled</option>
                        </select>
                        <small class="form-text text-muted">This is the only field you can edit</small>
                    </div>
                    
                    {% if order.items|length > 0 %}
                    <div class="mb-3">
                        <label class="form-label">Order Items</label>
                        <div class="border rounded p-3 bg-light">
                            <ul class="list-unstyled mb-0">
                            {% for item in order.items %}
                                <li class="mb-2">
                                    <strong>{{ item.product.name }}</strong> - 
                                    Quantity: {{ item.quantity }} - 
                                    Price: ₱{{ (item.price * item.quantity)|number_format(2, '.', ',') }}
                                </li>
                            {% endfor %}
                            </ul>
                            <hr>
                            <div class="text-end">
                                <strong>Total: </strong>
                                {% set total = 0 %}
                                {% for item in order.items %}
                                    {% set total = total + (item.price * item.quantity) %}
                                {% endfor %}
                                <span class="fs-5 text-primary">₱{{ total|number_format(2, '.', ',') }}</span>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                    
                    <button type="submit" class="btn btn-primary">Update Status</button>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-0">Current Status</h5>
            </div>
            <div class="card-body text-center">
                {% if order.status == 'Pending' %}
                    <span class="badge bg-warning text-dark fs-5 p-3">{{ order.status }}</span>
                {% elseif order.status == 'Approved' %}
                    <span class="badge bg-info fs-5 p-3">{{ order.status }}</span>
                {% elseif order.status == 'Completed' %}
                    <span class="badge bg-success fs-5 p-3">{{ order.status }}</span>
                {% elseif order.status == 'Cancelled' %}
                    <span class="badge bg-danger fs-5 p-3">{{ order.status }}</span>
                {% else %}
                    <span class="badge bg-secondary fs-5 p-3">{{ order.status }}</span>
                {% endif %}
            </div>
        </div>
        
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">Danger Zone</h5>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">Deleting this order is permanent and cannot be undone.</p>
                {{ include('orders/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a href="{{ path('app_orders_index') }}" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to list
    </a>
</div>
{% endblock %}